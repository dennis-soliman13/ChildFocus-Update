<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EE000000"
    android:padding="28dp"
    android:gravity="center">

    <!-- Shield Icon -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_childfocus_shield"
        android:layout_marginBottom="16dp"/>

    <!-- Main blocked / break title -->
    <TextView
        android:id="@+id/tvBlocked"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Content Blocked"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- OIR score (long-form) or message (Stage 3) -->
    <TextView
        android:id="@+id/tvScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#AAFFFFFF"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- Countdown timer — visible only during Stage 3 cooldown -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:gravity="center"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp"
        android:visibility="gone"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginBottom="20dp"/>

    <!-- Suggestions label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Watch something better instead:"
        android:textSize="14sp"
        android:textColor="#CCFFFFFF"
        android:layout_marginBottom="12dp"/>

    <!-- Loading spinner while suggestions fetch -->
    <ProgressBar
        android:id="@+id/pbSuggestions"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:indeterminateTint="#FFFFFF"
        android:visibility="visible"
        android:layout_marginBottom="8dp"/>

    <!-- Suggestion buttons injected at runtime -->
    <LinearLayout
        android:id="@+id/llSuggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp"/>

    <!-- Dismiss button — hidden for Stage 3, shown for long-form -->
    <Button
        android:id="@+id/btnClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dismiss"
        android:textColor="#000000"
        android:backgroundTint="#FFFFFF"
        android:paddingHorizontal="32dp"
        android:layout_marginTop="8dp"/>

</LinearLayout>


